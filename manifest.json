{
  "manifest_version": 3,
  "name": "Mi Buscador NetSuite",
  "version": "1.0",
  "description": "Filtro rápido para campos en Saved Searches",
  "permissions": ["activeTab"],
  "browser_specific_settings": {
    "gecko": {
      "id": "mibuscador@mi-dominio.com",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.netsuite.com/*"],
      "js": ["polyfill.js", "content.js"]
    }
  ]
}